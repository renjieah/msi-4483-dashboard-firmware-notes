<Window x:Class="PanelRuntime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PanelRuntime"
        Icon="assets/app/panel-runtime.ico"
        Width="760"
        Height="900"
        MinWidth="620"
        MinHeight="780"
        Background="#111318"
        Foreground="#E8ECF3">
  <Grid Margin="14">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="18" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Width="480"
            Height="800"
            Background="#05070A"
            BorderBrush="#2A303A"
            BorderThickness="1"
            ClipToBounds="True">
      <wv2:WebView2 x:Name="PanelWebView"
                    Width="480"
                    Height="800" />
    </Border>

    <StackPanel Grid.Column="2">
      <TextBlock Text="PanelRuntime"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Margin="0,0,0,16" />

      <UniformGrid Columns="2" Rows="5" Margin="0,0,0,14">
        <TextBlock Text="Mode" Foreground="#AEB7C5" />
        <TextBlock x:Name="ModeText" />
        <TextBlock Text="AIDA64" Foreground="#AEB7C5" />
        <TextBlock x:Name="AidaText" />
        <TextBlock Text="Dashboard" Foreground="#AEB7C5" />
        <TextBlock x:Name="DashboardText" />
        <TextBlock Text="Frames" Foreground="#AEB7C5" />
        <TextBlock x:Name="FrameText" />
        <TextBlock Text="Last Error" Foreground="#AEB7C5" />
        <TextBlock x:Name="ErrorText" TextWrapping="Wrap" />
      </UniformGrid>

      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <Button x:Name="StartButton"
                Content="Start"
                Padding="18,8"
                Margin="0,0,8,0"
                Click="StartButton_Click" />
        <Button x:Name="StopButton"
                Content="Stop"
                Padding="18,8"
                Margin="0,0,8,0"
                IsEnabled="False"
                Click="StopButton_Click" />
        <Button x:Name="SimClickButton"
                Content="Sim Click"
                Padding="18,8"
                Click="SimClickButton_Click" />
      </StackPanel>

      <TextBox x:Name="LogBox"
               Height="610"
               Background="#0B0E13"
               Foreground="#D7DCE6"
               BorderBrush="#2A303A"
               FontFamily="Consolas"
               FontSize="12"
               IsReadOnly="True"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto" />
    </StackPanel>
  </Grid>
</Window>
